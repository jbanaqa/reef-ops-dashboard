generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model FeedbackItem {
  id String @id @default(cuid())

  source            String
  sourceUrl         String?
  customerReference String?
  feedbackText      String
  staffNote         String?

  aiSentiment           String
  aiIssueTypes          String
  aiSeverity            String
  aiValidityEstimate    String
  aiSuggestedStatus     String
  aiConfidence          Float
  aiSummary             String
  aiSuggestedNextAction String
  aiSuggestedResponse   String?
  aiMissingInformation  String

  status String @default("New")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScanResult {
  id String @id @default(cuid())

  source      String  @default("Brave Search")
  query       String
  title       String
  url         String  @unique
  domain      String?
  description String?
  age         String?
  sourceName  String?
  sourceUrl   String?

  status String @default("New")

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventorySnapshot {
  id String @id @default(cuid())

  shop String

  productId       String?
  variantId       String?
  inventoryItemId String
  locationId      String

  sku          String?
  productTitle String?
  variantTitle String?
  locationName String?

  available Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, inventoryItemId, locationId])
  @@index([shop])
  @@index([inventoryItemId])
  @@index([variantId])
  @@index([locationId])
}

model RawInventoryUpdate {
  id String @id @default(cuid())

  shop String

  inventoryItemId String
  locationId      String

  available  Int
  rawPayload String?

  receivedAt DateTime @default(now())

  @@index([shop])
  @@index([inventoryItemId])
  @@index([locationId])
  @@index([receivedAt])
}

model InventoryMovementWindow {
  id String @id @default(cuid())

  shop String

  productId       String?
  variantId       String?
  inventoryItemId String
  locationId      String

  sku          String?
  productTitle String?
  variantTitle String?
  locationName String?

  startingAvailable Int
  latestAvailable   Int
  netDelta          Int

  firstChangeAt DateTime
  lastChangeAt  DateTime
  finalizeAfter DateTime

  status String @default("Pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([inventoryItemId])
  @@index([variantId])
  @@index([locationId])
  @@index([status])
  @@index([finalizeAfter])
}

model InventoryEvent {
  id String @id @default(cuid())

  shop String

  productId       String?
  variantId       String?
  inventoryItemId String
  locationId      String

  sku          String?
  productTitle String?
  variantTitle String?
  locationName String?

  startingAvailable Int
  endingAvailable   Int
  netDelta          Int

  matchedOrderQuantity  Int @default(0)
  unknownChangeQuantity Int @default(0)

  eventType String

  matchedOrderIds   String?
  matchedOrderNames String?

  reviewStatus String @default("Unreviewed")

  ownerNote String?

  detectedAt DateTime  @default(now())
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([inventoryItemId])
  @@index([variantId])
  @@index([locationId])
  @@index([eventType])
  @@index([reviewStatus])
  @@index([detectedAt])
}

model OrderInventoryClaim {
  id String @id @default(cuid())

  shop String

  orderId   String
  orderName String?

  productId       String?
  variantId       String?
  inventoryItemId String?

  sku          String?
  productTitle String?
  variantTitle String?

  quantitySold    Int
  claimedQuantity Int @default(0)

  orderCreatedAt DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
  @@index([orderId])
  @@index([variantId])
  @@index([inventoryItemId])
  @@index([orderCreatedAt])
}

model ProductRestockWaitlist {
  id String @id @default(cuid())

  shop String

  productId     String
  productHandle String?
  productTitle  String?

  email String

  status String @default("Waiting")

  subscribedAt     DateTime  @default(now())
  notifiedAt       DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String    @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([productId])
  @@index([email])
  @@index([status])
  @@index([subscribedAt])
}

// -----------------------------------------------------------------------------
// REORDER PLANNER
// -----------------------------------------------------------------------------

model SupplierItem {
  id String @id @default(cuid())

  supplierCode           String @unique
  supplierName           String
  normalizedSupplierName String

  latestAvailableQty Int?
  lastSeenAt         DateTime?

  reorderMapping ReorderMapping?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierName])
  @@index([normalizedSupplierName])
  @@index([lastSeenAt])
}

model ReorderMapping {
  id String @id @default(cuid())

  supplierItemId String?       @unique
  supplierItem   SupplierItem? @relation(fields: [supplierItemId], references: [id], onDelete: SetNull)

  supplierCode String? @unique

  supplierName           String
  normalizedSupplierName String @unique

  targetStockQuantity Int
  isActive            Boolean @default(true)

  variants ReorderVariantMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierCode])
  @@index([supplierName])
  @@index([isActive])
}

model ReorderVariantMapping {
  id String @id @default(cuid())

  mappingId String
  mapping   ReorderMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  shop String @default("corals-anonymous.myshopify.com")

  productId       String?
  variantId       String
  inventoryItemId String?

  productTitle String
  variantTitle String?
  sku          String?

  unitsPerVariant Int @default(1)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mappingId, shop, variantId])
  @@index([mappingId])
  @@index([variantId])
  @@index([inventoryItemId])
  @@index([isActive])
}

// -----------------------------------------------------------------------------
// COLLECTION ROTATION
// -----------------------------------------------------------------------------

model CollectionRotation {
  id String @id @default(cuid())

  shop String

  shopifyCollectionId String
  collectionTitle     String
  collectionHandle    String?

  isEnabled Boolean @default(false)
  isStarred Boolean @default(false)

  controlledTopCount Int @default(0)

  lastShuffledAt DateTime?
  lastStatus     String?
  lastError      String?

  runs               CollectionRotationRun[]
  controlledProducts CollectionControlledProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, shopifyCollectionId])
  @@index([shop])
  @@index([shopifyCollectionId])
  @@index([isEnabled])
  @@index([isStarred])
  @@index([controlledTopCount])
  @@index([lastShuffledAt])
}

model CollectionRotationRun {
  id String @id @default(cuid())

  rotationId String
  rotation   CollectionRotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)

  shop                String
  shopifyCollectionId String
  collectionTitle     String

  triggerType String @default("Manual")
  status      String @default("Pending")

  productCount Int @default(0)

  previousProductIds Json
  shuffledProductIds Json?

  shopifyJobIds Json?

  errorMessage String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  undoneAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rotationId])
  @@index([shop])
  @@index([shopifyCollectionId])
  @@index([triggerType])
  @@index([status])
  @@index([startedAt])
}

model CollectionControlledProduct {
  id String @id @default(cuid())

  rotationId String
  rotation   CollectionRotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)

  shopifyProductId String
  productTitle     String
  productHandle    String?
  imageUrl         String?

  position Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rotationId, position])
  @@unique([rotationId, shopifyProductId])
  @@index([rotationId])
  @@index([shopifyProductId])
}

model CollectionRotationScheduleRun {
  id String @id @default(cuid())

  scheduledFor DateTime @unique

  status String @default("Running")

  enabledCount   Int @default(0)
  completedCount Int @default(0)
  failedCount    Int @default(0)

  results Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledFor])
  @@index([status])
  @@index([startedAt])
}
